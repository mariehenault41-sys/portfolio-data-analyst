        <calculation class='tableau' formula='[Population using at least basic drinking-water services (%)] &#13;&#10;- [Population using safely managed drinking-water services (%)]' />
      </column>
      <column caption='Sans accès' datatype='real' name='[Calculation_989947503256920065]' role='measure' type='quantitative'>
