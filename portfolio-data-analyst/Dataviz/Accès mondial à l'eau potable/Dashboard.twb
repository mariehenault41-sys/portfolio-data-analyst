      <column caption='Total' datatype='real' name='[Calculation_989947503264067588]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Population using safely managed drinking-water services (%)]) THEN&#13;&#10;    IF ISNULL([Population using at least basic drinking-water services (%)]) THEN&#13;&#10;        NULL&#13;&#10;    ELSE&#13;&#10;        [Population using at least basic drinking-water services (%)] + (100 - [Population using at least basic drinking-water services (%)])&#13;&#10;    END&#13;&#10;ELSE&#13;&#10;    IF ISNULL([Population using at least basic drinking-water services (%)]) THEN&#13;&#10;        [Population using safely managed drinking-water services (%)] + NULL&#13;&#10;    ELSE&#13;&#10;        [Population using safely managed drinking-water services (%)]&#13;&#10;        + ([Population using at least basic drinking-water services (%)] - [Population using safely managed drinking-water services (%)])&#13;&#10;        + (100 - [Population using at least basic drinking-water services (%)] )&#13;&#10;    END&#13;&#10;END' />
      </column>
